---
layout: base.njk
lang: fr
pageTitle: "VDV Digital — Charles Van de Voorde"
metaDesc: "Expert en gestion de projets digitaux, IA et automatisation. VDV Digital accompagne les entreprises dans leur transformation."
permalink: /fr/index.html
---

<!-- ══════════════════════════════════════════════
     HERO
══════════════════════════════════════════════ -->
<section class="hero" id="accueil">
  <div class="hero__inner">

    <!-- Photo à GAUCHE -->
    <div class="hero__photo-wrap fade-in">
      <img
        src="/assets-source/photo-profil.png"
        alt="Charles Van de Voorde — Fondateur VDV Digital"
        class="hero__photo"
        loading="eager"
      />
    </div>

    <!-- Texte à DROITE -->
    <div class="hero__content fade-in">
      <h1 class="hero__title">Charles<br>Van&nbsp;de&nbsp;Voorde</h1>
      <p class="hero__subtitle">{{ home_fr.hero_sous_titre }}</p>
      <p class="hero__founder">{{ home_fr.hero_fondateur }}</p>
      <p class="hero__tagline">{{ home_fr.hero_tagline }}</p>
      <div class="hero__ctas">
        <a href="#portfolio" class="btn btn--primary">{{ home_fr.hero_cta_principal }}</a>
        <a href="#contact" class="btn btn--outline">{{ home_fr.hero_cta_secondaire }}</a>
      </div>
    </div>

  </div>
  <div class="hero__scroll">Scroll</div>
</section>

<!-- Dégradé hero → services -->
<div class="gradient-divider gradient-divider--cream-white" aria-hidden="true"></div>

<!-- ══════════════════════════════════════════════
     SERVICES
══════════════════════════════════════════════ -->
<section class="section section--white" id="services">
  <div class="container">
    <p class="section-label">{{ home_fr.services_label }}</p>
    <h2 class="section-title fade-in">{{ home_fr.services_titre }}</h2>
    <p class="section-intro fade-in">{{ home_fr.services_intro }}</p>
    <div class="services__grid fade-in-children">

      <div class="service-card">
        <span class="service-card__icon">🤖</span>
        <h3 class="service-card__title">IA &amp; Automatisation</h3>
        <p class="service-card__desc">
          Intégration d'IA dans les processus métier, automatisation de workflows
          répétitifs, sélection et déploiement d'outils adaptés à vos besoins réels.
        </p>
      </div>

      <div class="service-card">
        <span class="service-card__icon">⚡</span>
        <h3 class="service-card__title">No-Code &amp; Low-Code</h3>
        <p class="service-card__desc">
          Conception de solutions sur mesure sans développement lourd — outils, apps
          internes, bases de données, automatisations. Rapide, économique, évolutif.
        </p>
      </div>

      <div class="service-card">
        <span class="service-card__icon">📣</span>
        <h3 class="service-card__title">Marketing Digital</h3>
        <p class="service-card__desc">
          SEO, CRM, rebranding, stratégie de contenu et réseaux sociaux. Croissance
          mesurable grâce à des actions alignées avec vos objectifs business.
        </p>
      </div>

      <div class="service-card">
        <span class="service-card__icon">🗂️</span>
        <h3 class="service-card__title">Gestion de Projets Digitaux</h3>
        <p class="service-card__desc">
          AMOA SI, chefferie de projet, pilotage de roadmaps produit et coordination
          d'équipes pluridisciplinaires. De la définition des besoins à la livraison.
        </p>
      </div>

    </div>
  </div>
</section>

<!-- Dégradé services → portfolio -->
<div class="gradient-divider gradient-divider--white-cream" aria-hidden="true"></div>

<!-- ══════════════════════════════════════════════
     PORTFOLIO
══════════════════════════════════════════════ -->
<section class="section section--cream" id="portfolio">
  <div class="container">
    <p class="section-label">Réalisations</p>
    <h2 class="section-title fade-in">Mes projets</h2>
    <p class="section-intro fade-in">
      Une sélection de projets professionnels et personnels — de la gestion de SI
      à la photographie, en passant par l'IA et le marketing digital.
    </p>

    <!-- Filtres -->
    <div class="portfolio__filters fade-in">
      <button class="filter-btn active" data-filter="all">Tous</button>
      <button class="filter-btn" data-filter="ia">IA &amp; Auto.</button>
      <button class="filter-btn" data-filter="marketing">Marketing</button>
      <button class="filter-btn" data-filter="consulting">Consulting</button>
      <button class="filter-btn" data-filter="crea">Créa</button>
    </div>

    <div class="portfolio__grid">

      {% for projet in collections.projets_fr %}
      {% set cat = projet.data.categorie | lower %}
      <div class="project-card" data-category="{{ cat }}">
        <div class="project-card__thumb">
          {% if projet.data.type == "externe" %}
          <a href="{{ projet.data.url_externe }}" target="_blank" rel="noopener" aria-label="Voir {{ projet.data.titre }}">
          {% else %}
          <a href="/fr/projets/{{ projet.fileSlug }}/" aria-label="Voir {{ projet.data.titre }}">
          {% endif %}
            <img
              src="{{ projet.data.image }}"
              alt="{{ projet.data.titre }}"
              {% if projet.data.image_style == "contain" %}style="object-fit:contain; background:#f0ede6; padding:1.5rem;"{% endif %}
            />
            <div class="project-card__overlay">
              <span>{% if projet.data.type == "externe" %}Voir ↗{% else %}Voir →{% endif %}</span>
            </div>
          </a>
        </div>
        <div class="project-card__body">
          <span class="project-card__tag">{{ projet.data.tag_affiche or projet.data.categorie }}</span>
          <h3 class="project-card__title">{{ projet.data.titre }}</h3>
          <p class="project-card__desc">{{ projet.data.description }}</p>
        </div>
      </div>
      {% endfor %}

    </div>

    <div style="text-align:center; margin-top:2.5rem;">
      <button id="portfolio-voir-plus" class="btn btn--outline" style="display:none;">
        Voir plus de projets ↓
      </button>
    </div>

  </div>
</section>

<!-- Dégradé portfolio → témoignages -->
<div class="gradient-divider gradient-divider--cream-green" aria-hidden="true"></div>

