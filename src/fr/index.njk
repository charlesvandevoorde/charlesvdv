<!-- Dégradé témoignages → contact -->
<div class="gradient-divider gradient-divider--green-white" aria-hidden="true"></div>

<!-- ══════════════════════════════════════════════
     CONTACT
══════════════════════════════════════════════ -->
<section class="section section--white" id="contact">
  <div class="container">
    <p class="section-label">Parlons-nous</p>
    <h2 class="section-title fade-in">Me contacter</h2>

    <div class="contact__inner">
      <div class="contact__info fade-in">
        <h3>Travaillons ensemble</h3>
        <p>
          Vous avez un projet digital, une mission de conseil, ou simplement une question ?
          Je réponds dans les 24h.
        </p>
        <a href="mailto:charles.vandevoorde@gmail.com" class="contact__link">
          <span class="contact__link-icon">✉️</span>
          charles.vandevoorde@gmail.com
        </a>
        <a href="https://www.linkedin.com/in/charles-van-de-voorde/" target="_blank" rel="noopener" class="contact__link">
          <span class="contact__link-icon">💼</span>
          linkedin.com/in/charles-van-de-voorde
        </a>
        <a href="/public/cv-charles-vdv.pdf" target="_blank" rel="noopener" class="btn btn--outline" style="margin-top:0.5rem; align-self:flex-start;">
          📄 Télécharger mon CV
        </a>
      </div>

      <div class="fade-in">
        <div class="form__success" role="alert">
          ✅ Message envoyé ! Je vous réponds dans les 24h.
        </div>
        <form
          name="contact"
          class="form contact-form"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p style="display:none;">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </p>

          <div class="form__row">
            <div class="form__group">
              <label class="form__label" for="name">Nom *</label>
              <input class="form__input" type="text" id="name" name="name" required placeholder="Votre nom" />
            </div>
            <div class="form__group">
              <label class="form__label" for="email">Email *</label>
              <input class="form__input" type="email" id="email" name="email" required placeholder="votre@email.com" />
            </div>
          </div>

          <div class="form__group">
            <label class="form__label" for="sujet">Sujet *</label>
            <select class="form__select" id="sujet" name="sujet" required>
              <option value="">Sélectionner...</option>
              <option value="Projet">💼 Projet</option>
              <option value="Mission">🎯 Mission freelance</option>
              <option value="Autre">💬 Autre</option>
            </select>
          </div>

          <div class="form__group">
            <label class="form__label" for="message">Message *</label>
            <textarea class="form__textarea" id="message" name="message" required placeholder="Décrivez votre projet ou votre besoin..."></textarea>
          </div>

          <button type="submit" class="btn btn--primary">
            Envoyer le message →
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
